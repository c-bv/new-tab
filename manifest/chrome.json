{
    "name": "Homepage",
    "description": "Base Level Extension",
    "version": "1.0",
    "manifest_version": 3,
    "action": {
        "default_popup": "index.html",
        "default_title": "Open the popup"
    },
    "chrome_url_overrides": {
        "newtab": "index.html"
    },
    "background": {
        "service_worker": "scripts/background.js"
    },
    "permissions": [
        "storage",
        "activeTab",
        "tabs"
    ]
}